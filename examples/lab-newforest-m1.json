{
  "metadata": {
    "configVersion": "0.1",
    "description": "Minimal ADBuilder M1 lab forest",
    "author": "ADBuilder"
  },
  "mode": "newForest",
  "execution": {
    "labMode": true,
    "reconcile": {
      "global": {
        "default": "additive"
      },
      "perType": {
        "users": {
          "mode": "update",
          "allowMove": false,
          "allowPasswordReset": false
        },
        "groups": {
          "mode": "additive",
          "allowDelete": false
        },
        "ous": {
          "mode": "additive",
          "allowDelete": false
        }
      }
    }
  },
  "forest": {
    "domainName": "adbuilder.lab",
    "netbiosName": "ADBUILDER",
    "installDns": true,
    "dsrmPassword": {
      "source": "env",
      "name": "ADBUILDER_DSRM_PASSWORD"
    },
    "forestMode": "WinThreshold",
    "domainMode": "WinThreshold",
    "databasePath": "C:\\Windows\\NTDS",
    "logPath": "C:\\Windows\\NTDS",
    "sysvolPath": "C:\\Windows\\SYSVOL"
  },
  "providers": {
    "directory": {
      "enabled": true,
      "ous": [
        {
          "name": "Lab",
          "children": [
            {
              "name": "Users"
            },
            {
              "name": "Groups"
            },
            {
              "name": "Computers"
            }
          ]
        }
      ],
      "groups": [
        {
          "name": "Lab-Users",
          "ou": "OU=Groups,OU=Lab",
          "scope": "Global",
          "category": "Security",
          "description": "M1 lab users",
          "members": [],
          "memberOf": []
        },
        {
          "name": "Lab-Computers",
          "ou": "OU=Groups,OU=Lab",
          "scope": "Global",
          "category": "Security",
          "description": "M1 lab computers",
          "members": [
            "WEB01"
          ]
        }
      ],
      "users": [
        {
          "samAccountName": "alice",
          "givenName": "Alice",
          "surname": "Martin",
          "displayName": "Alice Martin",
          "userPrincipalName": "alice@adbuilder.lab",
          "ou": "OU=Users,OU=Lab",
          "enabled": true,
          "password": {
            "source": "env",
            "name": "ADBUILDER_DEFAULT_USER_PASSWORD"
          },
          "passwordNeverExpires": true,
          "groups": [
            "Lab-Users"
          ],
          "spns": [],
          "accountControlFlags": []
        }
      ],
      "computers": [
        {
          "name": "WEB01",
          "ou": "OU=Computers,OU=Lab",
          "enabled": true,
          "description": null
        }
      ],
      "sites": [],
      "siteLinks": [],
      "fineGrainedPasswordPolicies": [
        {
          "name": "LabUsers-PasswordPolicy",
          "precedence": 100,
          "minPasswordLength": 12,
          "passwordHistoryCount": 24,
          "complexityEnabled": true,
          "reversibleEncryptionEnabled": false,
          "lockoutThreshold": 0,
          "lockoutDuration": "00:30:00",
          "lockoutObservationWindow": "00:30:00",
          "maxPasswordAge": "42.00:00:00",
          "minPasswordAge": "1.00:00:00",
          "appliesTo": [
            "Lab-Users"
          ]
        }
      ],
      "delegations": [],
      "aclEdges": []
    }
  },
  "assertions": [
    {
      "type": "userExists",
      "identity": "alice"
    },
    {
      "type": "groupExists",
      "identity": "Lab-Users"
    },
    {
      "type": "memberOf",
      "principal": "alice",
      "group": "Lab-Users",
      "recursive": false
    },
    {
      "type": "groupExists",
      "identity": "Lab-Computers"
    },
    {
      "type": "memberOf",
      "principal": "WEB01",
      "group": "Lab-Computers",
      "recursive": false
    }
  ],
  "labVulnerabilities": {
    "enabled": false,
    "items": []
  }
}